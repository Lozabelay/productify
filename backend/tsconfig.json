{

  

"compilerOptions": {

    "target": "ES2022",

    "module": "commonjs",

    "moduleResolution": "node",

    "rootDir": "Src",

    "outDir": "./dist",



    "strict": true,

    "esModuleInterop": true,

    "skipLibCheck": true,



    "forceConsistentCasingInFileNames": true,

    "resolveJsonModule": true,



    "sourceMap": true

  },



  "include": ["Src/**/*.ts"],

  "exclude": ["node_modules"]

}